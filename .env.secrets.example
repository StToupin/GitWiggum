# Shared local-development secrets managed with sops + age.
#
# Copy is not loaded directly. It is only the template used to create and edit
# `secrets/shared.env`, which is the encrypted file committed to git.

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITLAB_CLIENT_ID=
OAUTH_GITLAB_CLIENT_SECRET=
POSTHOG_API_KEY=
OPENAI_API_KEY=
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
GITOKU_WORKFLOW_SECRET_KEY=
GITOKU_INTERNAL_HOOK_SECRET=
